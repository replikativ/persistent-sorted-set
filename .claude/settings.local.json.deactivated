      "Bash(/tmp/repro6.clj << 'CLEOF'\n\\(require '[org.replikativ.persistent-sorted-set :as set]\\)\n\\(import '[org.replikativ.persistent_sorted_set NumericStats NumericStatsOps]\\)\n\n\\(def stats-ops \\(NumericStatsOps.\\)\\)\n\n\\(let [elements [-6482 4107 6103 -330 9819 -336 7157 7311 3711 4011 1294 5323 8076 1459 -3617 8710 -1413 9841 -9473 -6007 8687 -8945 -7369 9655 -9106 5125 -4082 4951 9184 8676 3164 -9069 878 4319 -3947 -3230 7810 8400 9632 -2887 7571 8217 -3379 6182 -1224 -3870 8746 -2027 753 -9998 -5171 -1207 9493 -3200 9676 9261 -1894 -1104 4977 6208 -701 -9614 -5263 -1557 4111 6638 4170 1065 -6884 4329 -3086 -581 8360 488 -5206 -9611 -4049 8029 -5898 -4106 6262 4007 -8323 4046 -7181 9602 -5199 9181 6529 -1515 6560 4662 7717 -8100 4358 -5025 1833 -6213 -2463 3184 9333 -7678 -8206 -7997 4037 -5700 2966 8016 3605 -6200 -8618 919 9746 9478 5310 4143 8423 -7996 6169 -5526 7814 -6091 3228 -6853 3598 8054 -4244 -1224 -4389 9790 3788 -8507 7393 3654 5430 1382 4670 6681 -4157 5430 3124 2138 -4266 7161 -3960 4048 9958 8657 -6219 9631 3393 8343 -9496 2520 -4703 -8912 8042 -8299 8213 -5190 6840 8672 -6556 -279 -6596 -78 -8970 9083 -9075 -8209 -7681 4418 -9090 5433 -5442 9203 6452 -9613 -2835 7690 311 -3762 -5588 -9964 -8466 6353 -5658 5828 -2044 -382 4481 8450 1838 8827 -6813 283 7372 -374 -1441 -9433 7452 1512 -8385 -9886 -1007 -8302 -9777 -7127 6173 8520 8535 -1969 6101 868 7901]\n      adds [3637 -4254 -1843 6303 3736 -3284 -5043 -9158 -2279 -8641 6907 5092 2057 6160 9405 -827 -4237 1611 -740 -9404 2826 -6217 -5709 9078 -754 2823 2435 -3951 -458 -753 -750 6537 -3296 3619 843 9005 -4126 7669 3230 2494 1142 7242 5345 3574 -9606 -4741 -4626 -7660 -1523 3799 9643 -9196 -1383 6395 -9286 3766 344 3904 -6718 4683 -6298 4866 9598 6546 175 8948 -5077 -9645 3970 6188 7270 2527 -4655 2814 2134 7653 -3288 -2760 4029 -234 -9194 -6791]\n      removes [889 1828 -134 4593 -9018 6022 3110 -6861 -9564]\n      \n      ;; Check: are the removes actually present in the set after adds?\n      pss \\(into \\(set/sorted-set* {:measure stats-ops :branching-factor 8}\\) elements\\)\n      after-adds \\(-> \\(transient pss\\) \\(#\\(reduce conj! % adds\\)\\) persistent!\\)\n      _ \\(println \"count after adds:\" \\(count after-adds\\)\\)\n      _ \\(println \"removes that are in set:\" \\(filterv #\\(contains? after-adds %\\) removes\\)\\)\n      \n      after-both \\(-> \\(transient pss\\) \\(#\\(reduce conj! % adds\\)\\) \\(#\\(reduce disj! % removes\\)\\) persistent!\\)\n      _ \\(println \"count after both:\" \\(count after-both\\)\\)\n      \n      ;; Expected\n      expected-set \\(-> \\(into #{} elements\\) \\(into adds\\) \\(#\\(reduce disj % removes\\)\\)\\)\n      _ \\(println \"expected count:\" \\(count expected-set\\)\\)]\n  nil\\)\nCLEOF)",
