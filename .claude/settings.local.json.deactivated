      "Bash(/tmp/repro4.clj << 'CLEOF'\n\\(require '[org.replikativ.persistent-sorted-set :as set]\\)\n\\(import '[org.replikativ.persistent_sorted_set NumericStats NumericStatsOps ANode PersistentSortedSet]\\)\n\n\\(def stats-ops \\(NumericStatsOps.\\)\\)\n\n\\(defn stats->map [s]\n  \\(if \\(nil? s\\)\n    {:cnt 0 :sum 0.0 :min-val nil :max-val nil}\n    {:cnt \\(.-count ^NumericStats s\\)\n     :sum \\(.-sum ^NumericStats s\\)\n     :min-val \\(.-min ^NumericStats s\\)\n     :max-val \\(.-max ^NumericStats s\\)}\\)\\)\n\n;; Minimal repro - find the smallest case that fails\n\\(let [pss \\(into \\(set/sorted-set* {:measure stats-ops :branching-factor 8}\\) \\(range 1 20\\)\\)\n      _ \\(println \"before transient - measure:\" \\(stats->map \\(set/measure pss\\)\\)\\)\n      _ \\(println \"before transient - root measure:\" \\(.-_measure ^ANode \\(.root ^PersistentSortedSet pss\\)\\)\\)\n      result \\(-> \\(transient pss\\)\n                 \\(conj! 100\\)\n                 persistent!\\)\n      root \\(.root ^PersistentSortedSet result\\)\n      _ \\(println \"after transient - root._measure:\" \\(.-_measure ^ANode root\\)\\)\n      _ \\(println \"after transient - forceCompute:\" \\(.forceComputeMeasure ^ANode root nil\\)\\)\n      _ \\(println \"after transient - measure:\" \\(stats->map \\(set/measure result\\)\\)\\)]\n  nil\\)\nCLEOF)",
      "Bash(/tmp/repro5.clj << 'CLEOF'\n\\(require '[org.replikativ.persistent-sorted-set :as set]\\)\n\\(import '[org.replikativ.persistent_sorted_set NumericStats NumericStatsOps ANode PersistentSortedSet Branch Leaf]\\)\n\n\\(def stats-ops \\(NumericStatsOps.\\)\\)\n\n\\(defn stats->map [s]\n  \\(if \\(nil? s\\)\n    {:cnt 0 :sum 0.0 :min-val nil :max-val nil}\n    {:cnt \\(.-count ^NumericStats s\\)\n     :sum \\(.-sum ^NumericStats s\\)\n     :min-val \\(.-min ^NumericStats s\\)\n     :max-val \\(.-max ^NumericStats s\\)}\\)\\)\n\n\\(defn dump-tree [^ANode node depth]\n  \\(let [indent \\(apply str \\(repeat depth \"  \"\\)\\)]\n    \\(if \\(instance? Branch node\\)\n      \\(do\n        \\(println indent \"Branch len=\" \\(.-_len node\\)\n                 \"measure=\" \\(when \\(.-_measure node\\) \\(stats->map \\(.-_measure node\\)\\)\\)\n                 \"subtreeCount=\" \\(.-_subtreeCount ^Branch node\\)\\)\n        \\(dotimes [i \\(.-_len node\\)]\n          \\(let [raw \\(aget \\(.-_children ^Branch node\\) i\\)]\n            \\(when \\(instance? ANode raw\\)\n              \\(dump-tree raw \\(inc depth\\)\\)\\)\\)\\)\\)\n      \\(println indent \"Leaf len=\" \\(.-_len node\\) \n               \"measure=\" \\(when \\(.-_measure node\\) \\(stats->map \\(.-_measure node\\)\\)\\)\\)\\)\\)\\)\n\n\\(let [elements [-6482 4107 6103 -330 9819 -336 7157 7311 3711 4011 1294 5323 8076 1459 -3617 8710 -1413 9841 -9473 -6007 8687 -8945 -7369 9655 -9106 5125 -4082 4951 9184 8676 3164 -9069 878 4319 -3947 -3230 7810 8400 9632 -2887 7571 8217 -3379 6182 -1224 -3870 8746 -2027 753 -9998 -5171 -1207 9493 -3200 9676 9261 -1894 -1104 4977 6208 -701 -9614 -5263 -1557 4111 6638 4170 1065 -6884 4329 -3086 -581 8360 488 -5206 -9611 -4049 8029 -5898 -4106 6262 4007 -8323 4046 -7181 9602 -5199 9181 6529 -1515 6560 4662 7717 -8100 4358 -5025 1833 -6213 -2463 3184 9333 -7678 -8206 -7997 4037 -5700 2966 8016 3605 -6200 -8618 919 9746 9478 5310 4143 8423 -7996 6169 -5526 7814 -6091 3